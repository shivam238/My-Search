# Copy to .env and fill in your keys (never commit .env)
# cp .env.example .env

# Default provider for backup keys (gemini | openai | groq | grok | claude)
AI_PROVIDER=gemini

# Comma-separated = multiple backup keys per provider (tried one-by-one)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=

# --- Local dev: copy to project root .env, run: python3 server.py
# --- Firebase backup API: copy same .env to functions/.env before deploy:
#     cp .env functions/.env && firebase deploy --only functions,hosting
