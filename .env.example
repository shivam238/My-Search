# Copy to .env for LOCAL dev only (python3 server.py)
# cp .env.example .env

AI_PROVIDER=gemini

# Comma-separated = multiple keys per provider (tried one-by-one)
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=

# LOCAL: python3 server.py  →  http://localhost:5000  (.env auto-used)
# LIVE (free): Settings me user key, OR deploy worker/:
#   cd worker && npm i && npx wrangler secret bulk ../.env && npm run deploy
#   Settings → Backup API URL = https://mysearch-ai-backup.<you>.workers.dev
